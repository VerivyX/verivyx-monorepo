# playground-agent — sandboxed x402 playground backend (testnet only)
PORT=8087
NODE_ENV=production

# Stellar (testnet only — the service refuses to run otherwise)
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Verivyx internal services
HYDRATION_URL=http://hydration-service:8082

# OpenRouter (free model with tool-calling). Server-side only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cloudflare Turnstile (leave secret empty to enable a DEV bypass — local testing only)
TURNSTILE_SECRET_KEY=

# Faucet wallet that tops up session wallets with a little test USDC
PLAYGROUND_FAUCET_SECRET=
PLAYGROUND_FAUCET_USDC_PER_WALLET=0.5
PLAYGROUND_FAUCET_DAILY_CAP=50

# Default target: a real Verivyx SDK-protected site the agent pays via MCP (returns 402 to machines).
PLAYGROUND_DEMO_SDK_URL=https://demo-sdk-next.verivyx.com/seven-wonders

# Second playground target: a real Verivyx-protected WordPress post the agent can pay for.
PLAYGROUND_WEBTEST_URL=https://web-test.verivyx.com/2026/05/31/hello-world/

# Session limits
PLAYGROUND_POOL_SIZE=6
PLAYGROUND_MAX_SESSIONS=10
PLAYGROUND_SESSION_TTL_MIN=15

# Sandbox: comma-separated URL prefixes the agent's payment tool may fetch.
# Defaults to the real SDK demo site + web-test only.
ALLOWED_PAYMENT_PREFIXES=https://demo-sdk-next.verivyx.com/,https://web-test.verivyx.com/

# Fallback free models tried (in order) when the primary is rate-limited/busy (429).
# OPENROUTER_FALLBACK_MODELS=meta-llama/llama-3.3-70b-instruct:free,qwen/qwen-2.5-72b-instruct:free
# Optional CORS allowlist (default permissive). 
# CORS_ALLOWED_ORIGINS=https://verivyx.com
