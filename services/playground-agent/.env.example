# playground-agent — sandboxed x402 playground backend (testnet only)
PORT=8087
NODE_ENV=production

# Stellar (testnet only — the service refuses to run otherwise)
STELLAR_NETWORK=testnet
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
HORIZON_URL=https://horizon-testnet.stellar.org
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Verivyx internal services
HYDRATION_URL=http://hydration-service:8082

# OpenRouter (free model with tool-calling). Server-side only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Cloudflare Turnstile (leave secret empty to enable a DEV bypass — local testing only)
TURNSTILE_SECRET_KEY=

# Faucet wallet that tops up session wallets with a little test USDC
PLAYGROUND_FAUCET_SECRET=
PLAYGROUND_FAUCET_USDC_PER_WALLET=0.5
PLAYGROUND_FAUCET_DAILY_CAP=50

# Demo paywall (registered in DB + on-chain). DEMO_RESOURCE_URL is what the agent fetches.
PLAYGROUND_DEMO_DOMAIN=playground.verivyx.com
PLAYGROUND_DEMO_SLUG=article
PLAYGROUND_DEMO_RESOURCE_URL=http://127.0.0.1:8087/api/v1/playground/demo/article

# Session limits
PLAYGROUND_POOL_SIZE=6
PLAYGROUND_MAX_SESSIONS=10
PLAYGROUND_SESSION_TTL_MIN=15

# Sandbox: comma-separated URL prefixes the agent's payment tool may fetch.
# Defaults to the demo resource only.
ALLOWED_PAYMENT_PREFIXES=http://127.0.0.1:8087/api/v1/playground/demo,https://playground.verivyx.com/api/v1/playground/demo
