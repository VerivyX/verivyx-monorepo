# ---- Verivyx MCP server (mcp.verivyx.com) ----
# Service-specific vars. Shared vars (INTERNAL_TOKEN, STELLAR_NETWORK, USDC_ISSUER,
# HORIZON_URL, PLATFORM_STELLAR_ADDRESS) come from the repo-root .env.

# HTTP port (internal). nginx proxies mcp.verivyx.com/mcp here.
MCP_PORT=8088

# Comma-separated allowlist of API keys allowed to call /mcp (X-Verivyx-MCP-Key).
# While the public UI is coming-soon, only internal/playground/test callers hold a key.
# Admin-managed hashed keys replace this list later.
MCP_API_KEYS=

# Flat Verivyx service fee charged per successful payment (human USDC string).
MCP_FEE_USDC=0.001

# Dedicated MCP paying wallet for v1 (testnet). NEVER reuse FACILITATOR_STELLAR_SECRET
# or any other key. Must hold testnet USDC (classic trustline) + XLM for gas.
MCP_STELLAR_SECRET=

# Per-chain fee treasury. Defaults to PLATFORM_STELLAR_ADDRESS when unset.
MCP_FEE_TREASURY_STELLAR=

# Hard mainnet guard. Must be true to run any mainnet chain. Keep false for v1.
MCP_MAINNET_ENABLED=false

# Optional URL allowlist for payments (comma-separated prefixes). Empty = allow all.
MCP_ALLOWED_PAYMENT_PREFIXES=

# Optional Redis for the rate limiter. Unset/empty = in-memory (single-instance,
# DEFAULT). Set when running multiple mcp-server instances so limits hold across
# them (shared fixed-window counter). Redis errors fail OPEN (allow). REDIS_URL is
# used as a fallback when MCP_REDIS_URL is unset.
MCP_REDIS_URL=

# Optional external x402 facilitator (for non-Verivyx resources that need bearer auth).
X402_FACILITATOR_URL=
X402_FACILITATOR_API_KEY=

# ---- EVM rail (Base) — F1. Enabled only when MCP_EVM_PRIVATE_KEY is set. ----
# EVM paying wallet (0x..). Base Sepolia: fund with testnet ETH (gas) + USDC.
MCP_EVM_PRIVATE_KEY=
# base-sepolia (testnet default) or base (mainnet, needs MCP_MAINNET_ENABLED).
EVM_NETWORK=base-sepolia
# Platform EVM treasury (0x..) for the 0.001 USDC service fee on Base.
MCP_FEE_TREASURY_EVM=
# Optional overrides (defaults: public Base RPC + Circle USDC for the network).
EVM_RPC_URL=
EVM_USDC_ADDRESS=

# ---- Solana rail — F2. Enabled only when MCP_SOLANA_SECRET is set. ----
# Solana paying wallet (base58 64-byte secret). Devnet: fund with SOL + USDC.
MCP_SOLANA_SECRET=
# devnet (testnet default) or mainnet (needs MCP_MAINNET_ENABLED).
SOLANA_NETWORK=devnet
# Platform Solana treasury (base58 address) for the 0.001 USDC service fee.
MCP_FEE_TREASURY_SOLANA=
# Optional overrides (defaults: public Solana RPC + Circle USDC for the network).
SOLANA_RPC_URL=
SOLANA_USDC_MINT=
