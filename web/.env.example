# dashboard-ui environment variables
# Copy to .env.local for local development.
# All NEXT_PUBLIC_* vars are baked into the browser bundle at build time.

# ── Core API ──────────────────────────────────────────────────────────────────
# Public API URL (auth-service / x402-gateway host). Required.
NEXT_PUBLIC_API_URL=https://api.verivyx.com

# Embed script origin. Usually same as NEXT_PUBLIC_API_URL.
NEXT_PUBLIC_EMBED_URL=https://api.verivyx.com

# Cloudflare Turnstile site key (public, browser-safe). Empty = bypass in dev.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Playground API origin. Empty = same-origin (nginx proxies /api/v1/playground/*).
NEXT_PUBLIC_PLAYGROUND_API=

# ── Non-custodial Wallet / Plan 3 ─────────────────────────────────────────────
# MCP server public URL (browser-facing). Used for /wallet/* API calls.
# Production: https://mcp.verivyx.com  (nginx routes to mcp-server:8088 internally)
# Local dev: http://localhost:8088
NEXT_PUBLIC_MCP_BASE_URL=http://localhost:8088

# Stellar network passphrase.
# Testnet:  Test SDF Network ; September 2015
# Mainnet:  Public Global Stellar Network ; September 2015
NEXT_PUBLIC_STELLAR_NETWORK=Test SDF Network ; September 2015

# Soroban RPC URL.
# Testnet:  https://soroban-testnet.stellar.org
# Mainnet:  https://soroban.stellar.org (or your own node)
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org

# USDC SAC contract ID on the target Stellar network.
# Testnet:  CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA
# Mainnet:  (deploy/check the official Stellar USDC SAC)
NEXT_PUBLIC_USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# OZ smart account WASM hash (must be uploaded to the target network).
# Testnet (uploaded): 40276717b7227725be75ad66ec2214aa95a29b47b36679a90f165be3f8fe09cb
# Mainnet: (upload separately and update this value)
NEXT_PUBLIC_OZ_ACCOUNT_WASM_HASH=40276717b7227725be75ad66ec2214aa95a29b47b36679a90f165be3f8fe09cb

# Deployed spending_limit Policy contract address (one instance serves all users).
# Testnet (deployed): CBGLHQVGQEWBWW6JJXKLLMQZL3G4ENHFRBORLAUO2ZYVAJ2EZWYVMZC2
# Mainnet: (deploy separately via spike 14-deploy-policy.js and update this value)
NEXT_PUBLIC_SPENDING_LIMIT_POLICY_ADDRESS=CBGLHQVGQEWBWW6JJXKLLMQZL3G4ENHFRBORLAUO2ZYVAJ2EZWYVMZC2
