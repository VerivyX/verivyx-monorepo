FROM node:20-alpine AS builder
WORKDIR /app
ARG NEXT_PUBLIC_API_URL
ARG NEXT_PUBLIC_EMBED_URL
ARG NEXT_PUBLIC_TURNSTILE_SITE_KEY
ARG NEXT_PUBLIC_PLAYGROUND_API
# Non-custodial wallet / Plan 3
ARG NEXT_PUBLIC_MCP_BASE_URL
ARG NEXT_PUBLIC_STELLAR_NETWORK
ARG NEXT_PUBLIC_STELLAR_RPC_URL
ARG NEXT_PUBLIC_USDC_CONTRACT_ID
ARG NEXT_PUBLIC_OZ_ACCOUNT_WASM_HASH
ARG NEXT_PUBLIC_SPENDING_LIMIT_POLICY_ADDRESS
ENV NEXT_PUBLIC_API_URL=$NEXT_PUBLIC_API_URL
ENV NEXT_PUBLIC_EMBED_URL=$NEXT_PUBLIC_EMBED_URL
ENV NEXT_PUBLIC_TURNSTILE_SITE_KEY=$NEXT_PUBLIC_TURNSTILE_SITE_KEY
ENV NEXT_PUBLIC_PLAYGROUND_API=$NEXT_PUBLIC_PLAYGROUND_API
ENV NEXT_PUBLIC_MCP_BASE_URL=$NEXT_PUBLIC_MCP_BASE_URL
ENV NEXT_PUBLIC_STELLAR_NETWORK=$NEXT_PUBLIC_STELLAR_NETWORK
ENV NEXT_PUBLIC_STELLAR_RPC_URL=$NEXT_PUBLIC_STELLAR_RPC_URL
ENV NEXT_PUBLIC_USDC_CONTRACT_ID=$NEXT_PUBLIC_USDC_CONTRACT_ID
ENV NEXT_PUBLIC_OZ_ACCOUNT_WASM_HASH=$NEXT_PUBLIC_OZ_ACCOUNT_WASM_HASH
ENV NEXT_PUBLIC_SPENDING_LIMIT_POLICY_ADDRESS=$NEXT_PUBLIC_SPENDING_LIMIT_POLICY_ADDRESS
COPY package*.json ./
RUN npm ci --prefer-offline
COPY . .
RUN npm run build

FROM node:20-alpine
WORKDIR /app
ENV NODE_ENV=production
ENV PORT=3000
ENV HOSTNAME=0.0.0.0
COPY --from=builder /app/.next/standalone ./
COPY --from=builder /app/.next/static ./.next/static
COPY --from=builder /app/public ./public
EXPOSE 3000
CMD ["node", "server.js"]
