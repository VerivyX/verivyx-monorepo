# ---- Required secrets — generate with: openssl rand -hex 32 ----
JWT_SECRET=
SESSION_SECRET=
INTERNAL_TOKEN=
POW_SALT=

# ---- Domain (VPS) ----
# Your public domain without https://
# Example: verivyx.com
DOMAIN=
# Full public URL of the FRONTEND app (dashboard-ui)
# Example: https://verivyx.com
PUBLIC_DOMAIN=
# Full public URL of the BACKEND API host. All frontend/embed/agent API calls and
# the gate.min.js script are served from here (nginx path-routes to the right
# service). Example: https://api.verivyx.com
API_PUBLIC_URL=

# ---- TLS / Let's Encrypt ----
# Email for certificate registration (required for HTTPS)
ACME_EMAIL=

# ---- Postgres ----
POSTGRES_USER=paywall_user
POSTGRES_PASSWORD=
POSTGRES_DB=paywall_db

# ---- Redis ----
REDIS_PASSWORD=

# ---- Stellar Network ----
STELLAR_NETWORK=testnet

# ---- Platform Wallet ----
PLATFORM_STELLAR_ADDRESS=

# ---- Admin ----
ADMIN_EMAIL=

# ---- Asset Configuration (USDC) ----
# Classic Stellar USDC issuer. Testnet has a built-in default (sandbox), so this
# is OPTIONAL on testnet. On MAINNET it is REQUIRED — gateway and payment-relayer
# refuse to start without it (real funds must never assume a default issuer).
# Testnet default: GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
USDC_ISSUER=

# ---- Facilitator (payment-relayer) ----
# proxy = real on-chain (production)
# stub  = no real TX, local dev only — ALSO set ALLOW_STUB_MODE=true
FACILITATOR_MODE=proxy
FACILITATOR_URL=http://payment-relayer:8084
# FACILITATOR_API_KEY=   # only if using third-party facilitator
# ALLOW_STUB_MODE=true   # local dev only — NEVER set in production

# ---- Stellar RPC (Optional — defaults to SDF public nodes per network) ----
# HORIZON_URL=
# SOROBAN_URL=
# Soroban RPC used for on-chain contract reads (registry lookups). STELLAR_RPC_URL
# and SOROBAN_RPC_URL are aliases read by different services — set both the same.
# STELLAR_RPC_URL=https://soroban-testnet.stellar.org
# SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# ---- Internal service URLs (Optional) ----
# Each service reaches the others over the docker network by service name. These
# defaults work for the bundled docker-compose; override only for custom topologies.
# REDIS_ADDR=redis:6379
# AUTH_SERVICE_URL=http://auth-service:8083
# GATEWAY_URL=http://x402-gateway:8081
# PAYMENT_RELAYER_URL=http://payment-relayer:8084
# MCP_SERVER_URL=http://mcp-server:8088
# MCP server URL the playground-agent connects to (Streamable HTTP endpoint).
# MCP_SERVER_URL_PLAYGROUND=http://mcp-server:8088/mcp

# ---- Soroban Contracts ----
# SOROBAN_PAYWALL_CONTRACT_ID=

# ---- Soroban USDC Contract (x402 spec-compliant Stellar payments) ----
# SEP-41 Soroban USDC token contract address for the configured network.
# *** TESTNET ONLY — this value must be replaced with the mainnet contract ID
# *** when STELLAR_NETWORK=mainnet. On mainnet the gateway will refuse to start
# *** if USDC_CONTRACT_ID is blank (mustEnv guard in main()).
# When set, gateway exposes a Soroban accepts entry (areFeesSponsored: true).
USDC_CONTRACT_ID=CBIELTK6YBZJU5UP2WWQEUCYKLPU6AUNZ2BQ4WWFEIE3USCIHMXQDAMA

# ---- Facilitator Keypair (required for Soroban fee sponsoring) ----
# Stellar secret key for the account that signs Soroban transactions as source.
# This account must hold XLM for transaction fees (≈ 0.00001 XLM per TX).
# Cost per TX is negligible vs platform fee earned (0.001 USDC ≈ 100–1000× larger).
# Generate: stellar-sdk Keypair.random().secret() or Stellar Laboratory
# NEVER reuse as PLATFORM_STELLAR_ADDRESS or any other key.
FACILITATOR_STELLAR_SECRET=

# Comma-separated allowlist of official paywall_core contract addresses the relayer will fee-sponsor
# + distribute against. REQUIRED for fee-sponsored Soroban settlement (fail-closed if empty).
ALLOWED_PAYWALL_CONTRACTS=

# Comma-separated allowlist of verivyx_pay_adapter contract addresses the relayer may fee-sponsor.
# On the adapter path the relayer ONLY sponsors — distribute is NOT called (the adapter splits atomically).
# Set to VERIVYX_PAY_ADAPTER_ID. Fail-closed: a tx targeting an adapter when empty is REJECTED.
ALLOWED_PAY_ADAPTERS=

# ---- PoW Security Tuning ----
POW_DIFFICULTY=18
POW_MIN_SOLVE_MS=50
# bcrypt cost for password hashing. Default 12. Above 14 may exceed the 1s SLA.
# BCRYPT_ROUNDS=12

# ---- Playground (playground.verivyx.com) ----
# Cloudflare Turnstile keys gating the sandboxed x402 playground.
# Leave BOTH empty for a local dev bypass (no captcha). In production set both.
# Site key is public — baked into the browser bundle at build time.
# Secret key is server-only — used by playground-agent to verify tokens.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Frontend → playground-agent origin. Empty = same-origin (recommended; nginx
# proxies /api/v1/playground/* to playground-agent). Set only for cross-origin setups.
PLAYGROUND_PUBLIC_API=
#
# -- playground-agent (the LLM-driven demo agent) --
# OpenRouter API key for the playground's free demo model. REQUIRED to run the
# playground-agent. https://openrouter.ai/keys
OPENROUTER_API_KEY=
# OPENROUTER_MODEL=openai/gpt-oss-120b:free
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Secret that signs the playground's per-session pooled testnet wallets. REQUIRED.
# Generate: openssl rand -hex 32. NEVER reuse another key.
PLAYGROUND_FAUCET_SECRET=
# Faucet + session tuning (optional — defaults shown).
# PLAYGROUND_FAUCET_USDC_PER_WALLET=0.5
# PLAYGROUND_FAUCET_DAILY_CAP=50
# PLAYGROUND_POOL_SIZE=6
# PLAYGROUND_MAX_SESSIONS=10
# PLAYGROUND_SESSION_TTL_MIN=15
# PLAYGROUND_DEMO_DOMAIN=playground.verivyx.com
# PLAYGROUND_DEMO_SLUG=article
# Sandbox allowlist — the demo agent may only pay these URL prefixes (comma-separated).
# Defaults cover the bundled demo resource; override only for custom topologies.
# ALLOWED_PAYMENT_PREFIXES=http://playground-agent:8087/api/v1/playground/demo,http://127.0.0.1:8087/api/v1/playground/demo,https://playground.verivyx.com/api/v1/playground/demo

# ---- Email (Resend) — register verification links ----
# Domain must be verified in Resend (DKIM/SPF DNS). Empty key → in dev the auth
# service logs the verification link to stdout instead of sending email.
RESEND_API_KEY=
# Sender label. No mailbox needs to exist — DKIM/SPF authenticate the domain.
RESEND_FROM=Verivyx <noreply@verivyx.com>
# Reply-to a real inbox to improve deliverability (avoid noreply-only). Empty →
# falls back to ADMIN_EMAIL. Recommended: a monitored address like hello@verivyx.com.
RESEND_REPLY_TO=
# Public base URL of the frontend, used to build user-facing links (e.g. the email
# verification link). Required. Example: https://verivyx.com
APP_BASE_URL=

# ---- Verivyx MCP server (mcp.verivyx.com) ----
# Remote x402 payment MCP. Pays any x402 resource and charges a flat service fee.
# v1 = internal/testnet only; public UI is coming-soon.
# Comma-separated allowlist of keys allowed to call /mcp (X-Verivyx-MCP-Key).
# Preferred form: label:<sha256hex>  e.g. playground:<hash>,admin:<hash>
# Generate a hash: printf %s "<key>" | sha256sum
# Plaintext entries are also accepted and hashed on load (backward-compatible):
#   MCP_API_KEYS=mysecretkey
# Hashed form (recommended for production):
#   MCP_API_KEYS=playground:$(printf %s "mysecretkey" | sha256sum | cut -d' ' -f1)
MCP_API_KEYS=
# Flat service fee per successful payment (human USDC string).
MCP_FEE_USDC=0.001
# Dedicated MCP paying wallet (testnet). NEVER reuse FACILITATOR_STELLAR_SECRET.
# Must hold testnet USDC (classic trustline) + XLM for gas.
MCP_STELLAR_SECRET=
# Per-chain fee treasury. Empty → defaults to PLATFORM_STELLAR_ADDRESS.
MCP_FEE_TREASURY_STELLAR=
# Hard mainnet guard. Must be true to run any mainnet chain. Keep false for v1.
MCP_MAINNET_ENABLED=false
# Trusted payment-URL prefixes (comma-separated). These BYPASS the SSRF guard
# (which otherwise requires public HTTPS and blocks private/link-local IPs).
# Empty = SSRF default-deny (public HTTPS only) — NOT "allow all".
# REQUIRED for the playground demo, whose resource is an internal http URL:
#   MCP_ALLOWED_PAYMENT_PREFIXES=http://playground-agent:8087
MCP_ALLOWED_PAYMENT_PREFIXES=http://playground-agent:8087
# DNS-rebinding defense for /mcp. Comma-separated allowlists; "*" disables a check.
# Defaults cover the public host + the internal docker name. Override if your host differs.
MCP_ALLOWED_HOSTS=mcp.verivyx.com,mcp-server:8088,localhost:8088,127.0.0.1:8088
MCP_ALLOWED_ORIGINS=https://mcp.verivyx.com,https://verivyx.com,https://docs.verivyx.com
# Optional external x402 facilitator (for non-Verivyx resources needing bearer auth).
X402_FACILITATOR_URL=
X402_FACILITATOR_API_KEY=
# --- EVM rail (Base) — F1. Enabled only when MCP_EVM_PRIVATE_KEY is set. ---
# EVM paying wallet (0x..). Base Sepolia: fund with testnet ETH (gas) + USDC.
# NEVER reuse another key. Non-custodial session keys replace this in F5.
MCP_EVM_PRIVATE_KEY=
# base-sepolia (testnet, default) or base (mainnet — needs MCP_MAINNET_ENABLED).
EVM_NETWORK=base-sepolia
# Platform EVM treasury (0x..) — where the 0.001 USDC fee lands on Base.
MCP_FEE_TREASURY_EVM=
# Optional RPC + USDC overrides (defaults: public Base RPC + Circle USDC).
EVM_RPC_URL=
EVM_USDC_ADDRESS=
# --- Solana rail — F2. Enabled only when MCP_SOLANA_SECRET is set. ---
# Solana paying wallet (base58 64-byte secret). Devnet: fund with SOL + USDC.
MCP_SOLANA_SECRET=
# devnet (testnet, default) or mainnet (needs MCP_MAINNET_ENABLED).
SOLANA_NETWORK=devnet
# Platform Solana treasury (base58 address) — where the 0.001 USDC fee lands.
MCP_FEE_TREASURY_SOLANA=
# Optional RPC + USDC mint overrides (defaults: public RPC + Circle USDC).
SOLANA_RPC_URL=
SOLANA_USDC_MINT=

# ---- MCP Wallet Binding (Plan 2: non-custodial settlement) ----
# AES-256-GCM key used by mcp-server to encrypt session signer secrets at rest.
# The owner master key is NEVER stored — only the budget-capped session key is encrypted here.
# If this key is unset, the wallet-binding feature is DISABLED (functions throw a clear error).
# DATABASE_URL is shared with auth-service (same paywall_db); the McpWallet table is
# created by auth-service's prisma migration 0006_mcp_wallets.
# Generate: openssl rand -hex 32  (produces 64 hex chars = 32 bytes)
MCP_WALLET_ENC_KEY=
# mcp-server shares JWT_SECRET with auth-service so the dashboard browser client can call
# /wallet/* endpoints using its paywall_token (HS256, audience "creator", claim id:number).
# The token's sub is resolved as String(id) — identical to the Hydra OAuth sub — so bindings
# created by the dashboard are found by agent callers using the same sub. When unset, only the
# Hydra OAuth path works for /wallet/*. Use the same value as the auth-service JWT_SECRET above.
# (JWT_SECRET is already declared in the "Required secrets" block at the top of this file.)

# ---- Ory Hydra (OAuth2 / OIDC engine) ----
# Stable public URL that Hydra uses as the OIDC issuer claim.
# Local/testnet: http://localhost:4444 (works with --dev; http:// OK).
# Production: MUST be https:// AND drop `--dev` from the hydra service command.
HYDRA_ISSUER=http://localhost:4444
# Login and consent endpoints in auth-service (built in Task 2 / Task 3).
# These must be concrete URLs — Compose does NOT reliably expand nested variable defaults.
HYDRA_LOGIN_URL=https://api.verivyx.com/api/v1/oauth/login
HYDRA_CONSENT_URL=https://api.verivyx.com/api/v1/oauth/consent
# System secret for Hydra cookie/token signing.
# Generate: openssl rand -hex 32. NEVER reuse any other secret. NEVER commit the real value.
HYDRA_SECRETS_SYSTEM=
# Admin API URL — used ONLY by internal services (auth-service Task 2).
# ⚠️ 4445 has NO host port mapping — it is network-internal only. NEVER expose publicly.
HYDRA_ADMIN_URL=http://hydra:4445
# JWKS endpoint mcp-server uses to verify JWT signatures. MUST use the docker service
# name (hydra:4444), NOT localhost — mcp-server runs inside the container network.
# HYDRA_ISSUER (the `iss` claim) uses localhost:4444 for local dev because Hydra's
# --dev mode advertises that as the public issuer, but key fetching happens internally.
HYDRA_JWKS_URL=http://hydra:4444/.well-known/jwks.json

# ---- Runtime ----
NODE_ENV=production
GIN_MODE=release

# ---- CORS (optional; default = permissive/reflect any origin, non-breaking) ----
# Restrict browser CORS for auth-service/payment-relayer/playground to an allowlist.
# Leave empty to keep the current permissive default. Public x402 endpoints stay open regardless.
# CORS_ALLOWED_ORIGINS=https://verivyx.com,https://www.verivyx.com,https://mcp.verivyx.com

# ---- Horizontal-scale (optional; default = in-memory single-instance) ----
# Set to enable Redis-backed facilitator lock + settle idempotency on payment-relayer
# (only needed when running MULTIPLE relayer instances). Unset = proven in-memory path.
# RELAYER_REDIS_URL=redis://redis:6379

# ---- x402 pay-adapter (trustless atomic-split path; deferred — keeper-distribute is the live path) ----
# VERIVYX_PAY_ADAPTER_ID=   # adapter contract id (must also be in ALLOWED_PAY_ADAPTERS)
